{
  "strategy": "additive",
  "localeFilter": {
    "filterType": "language",
    // "includeChildren": false,
    "whitelist": [
      "en_US",
      "ja_JP",
      "zh_CN",
      "zh_TW"
    ]
  },
  "featureFilters": {
